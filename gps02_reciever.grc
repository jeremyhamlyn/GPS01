    rotation: 0
    state: enabled

# ─── Constellation display (PLL output) ──────────────────────────────────────

- name: qtgui_const_sink_pll
  id: qtgui_const_sink_x
  parameters:
    affinity: ''
    alias: ''
    alpha1: '0.5'
    comment: "VISUALISATION \u2014 IQ constellation after PLL\n\
      BPSK nav data: should show two clusters at \xB1Re axis\n\
      Wide spread = poor lock; tight clusters = good tracking"
    gui_hint: 'tabs@1:0,2,1,1'
    label1: PLL Output
    legend: 'True'
    name: '"STEP 8: Costas PLL Output (should be BPSK)"'
    nconnections: '1'
    size: '1024'
    style1: '0'
    tr_chan: '0'
    tr_level: '0.0'
    tr_mode: qtgui.TRIG_MODE_FREE
    tr_tag: '""'
    type: complex
    update_time: '0.10'
    width1: '1'
    xmax: '2'
    xmin: '-2'
    ymax: '2'
    ymin: '-2'
  states:
    coordinate: [1260, 488]
    rotation: 0
    state: enabled

# ═══════════════════════════════════════════════════════════════
#  CONNECTIONS
#
#  Signal flow:
#   RTL-SDR → LPF → AGC ─────────────────────────────────┐
#                    │                                    │
#                    └→ RF viz                           │
#                                                        │
#   AGC → Multiply(correlation) ← PRN Gen              │
#         │                                             │
#   AGC → Multiply (port 0)                            │
#   PRN → Multiply (port 1)                            │
#         │                                             │
#         → Integrate&Dump → Acquisition              │
#                │                                    │
#                → Costas PLL → DLL → Nav Bit → Nav Parser
#                                  │
#                                  → Pseudorange → Position → NMEA
# ═══════════════════════════════════════════════════════════════

connections:
# ── Step 1 → Step 2 : RTL-SDR → LPF ──────────────────────────
- [rtlsdr_source_0, '0', low_pass_filter_0, '0']
- [rtlsdr_source_0, '0', qtgui_freq_sink_rf, '0']

# ── Step 2 → Step 3 : LPF → AGC ──────────────────────────────
- [low_pass_filter_0, '0', analog_agc2_cc_0, '0']
- [low_pass_filter_0, '0', qtgui_freq_sink_filtered, '0']

# ── Step 3 : AGC → visualise + correlator ─────────────────────
- [analog_agc2_cc_0, '0', qtgui_time_sink_agc, '0']
- [analog_agc2_cc_0, '0', blocks_multiply_cc_0, '0']
# AGC also feeds acquisition (raw signal for search)
- [analog_agc2_cc_0, '0', epy_acquisition, '0']
- [epy_acquisition, '0', blocks_null_sink_acq, '0']

# ── Step 4 : PRN Gen → correlator + visualise ─────────────────
- [epy_prn_generator, '0', blocks_multiply_cc_0, '1']
- [epy_prn_generator, '0', qtgui_time_sink_prn, '0']

# ── Step 5 → Step 6 : Correlator → Integrate & Dump ──────────
- [blocks_multiply_cc_0, '0', blocks_integrate_cc_0, '0']

# ── Step 6 → Step 8 : I&D → Costas PLL ───────────────────────
- [blocks_integrate_cc_0, '0', epy_costas_pll, '0']

# ── Step 8 : PLL → visualise + DLL ───────────────────────────
- [epy_costas_pll, '0', qtgui_const_sink_pll, '0']
- [epy_costas_pll, '0', epy_dll, '0']

# ── Step 9 : DLL → Nav Bit (prompt correlator port 0) ─────────
- [epy_dll, '0', epy_nav_bit_decoder, '0']
# DLL code phase (port 1) → Pseudorange Calculator ────────────
- [epy_dll, '1', epy_pseudorange_calc, '0']

# ── Step 10 → Step 11 : Nav Bits → Nav Message Parser ─────────
- [epy_nav_bit_decoder, '0', epy_nav_message_parser, '0']

# ── Message connections ────────────────────────────────────────
# Nav Parser → Pseudorange Calc (ephemeris)
- [epy_nav_message_parser, ephemeris, epy_pseudorange_calc, ephemeris]
# Pseudorange Calc → Position Solver
- [epy_pseudorange_calc, pseudorange, epy_position_solver, pseudorange]
# Position Solver → NMEA Encoder
- [epy_position_solver, position, epy_nmea_encoder, position]
# NMEA → debug console
- [epy_nmea_encoder, nmea, blocks_message_debug_0, print]

metadata:
  file_format: 1
