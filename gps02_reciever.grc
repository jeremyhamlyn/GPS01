# ═══════════════════════════════════════════════════════════════
#  STEP 3 — AUTOMATIC GAIN CONTROL
# ═══════════════════════════════════════════════════════════════

- name: analog_agc2_cc_0
  id: epy_block
  parameters:
    affinity: ''
    alias: ''
    comment: "STEP 3 \u2014 AUTOMATIC GAIN CONTROL (AGC)\n\
      Math: y(n) = x(n) \xD7 g(n)\n\
      g(n+1) = g(n) + rate\xB7(ref \u2212 |y(n)|\xB2)\xB7g(n)\n\
      Normalises amplitude so correlators see unit-power signal"
    _io_cache: '(''AGC'', ''blk'', [(''rate'', ''0.001''), (''reference'', ''1.0''),
      (''gain'', ''1.0''), (''max_gain'', ''65536.0'')], [(''0'', ''complex'', 1)],
      [(''0'', ''complex'', 1)], ''Automatic Gain Control for complex stream.'', {})'
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\n\nclass blk(gr.sync_block):\n    \"\"\"Automatic Gain Control.\"\"\"\n\n    def __init__(self, rate=0.001, reference=1.0, gain=1.0, max_gain=65536.0):\n        gr.sync_block.__init__(self, name='AGC', in_sig=[np.complex64], out_sig=[np.complex64])\n        self.rate = rate\n        self.reference = reference\n        self.gain = float(gain)\n        self.max_gain = float(max_gain)\n\n    def work(self, input_items, output_items):\n        inp = input_items[0]\n        out = output_items[0]\n        g = self.gain\n        for i in range(len(inp)):\n            y = inp[i] * g\n            out[i] = y\n            g += self.rate * (self.reference - abs(y) ** 2) * g\n            if g < 0.0:\n                g = 0.0\n            if g > self.max_gain:\n                g = self.max_gain\n        self.gain = g\n        return len(output_items[0])\n"
    gain: '1.0'
    max_gain: '65536.0'
    maxoutbuf: '0'
    minoutbuf: '0'
    rate: '1e-3'
    reference: '1.0'
  states:
    coordinate: [576, 288]
    rotation: 0
    state: enabled

- name: qtgui_time_sink_agc
  id: qtgui_time_sink_x
  parameters:
