# ═══════════════════════════════════════════════════════════════
#  STEP 2 — BANDPASS FILTER  (Anti-alias + GPS BW selection)
# ═══════════════════════════════════════════════════════════════

- name: low_pass_filter_0
  id: low_pass_filter
  parameters:
    affinity: ''
    alias: ''
    beta: '6.76'
    comment: "STEP 2 \u2014 BANDLIMIT FILTER\n\
      Math: H(f) = rect(f / 2\xB7BW)   [ideal]\n\
      FIR approximation with Kaiser window (\u03B2=6.76)\n\
      h(n) = 2\xB7BW\xB7sinc(2\xB7BW\xB7n) \xD7 w_Kaiser(n)\n\
      Convolution: y(t) = x(t) \u2217 h(t)\n\
      Cutoff = 2.046 MHz (= 2\xD7chip_rate) — preserves C/A main lobe\n\
      Transition BW = 500 kHz — removes adjacent channels\n\
      Removes: interference, adjacent signals, and out-of-band noise"
    decim: '1'
    gain: '1'
    interp: '1'
    maxoutbuf: '0'
    minoutbuf: '0'
    cutoff_freq: '2046000'
    samp_rate: samp_rate
    type: fir_filter_ccf
    width: '500000'
    win: window.WIN_KAISER
  states:
    coordinate: [288, 288]
    rotation: 0
    state: enabled

- name: qtgui_freq_sink_filtered
  id: qtgui_freq_sink_x
  parameters:
    affinity: ''
    alias: ''
    alpha1: '1.0'
    autoscale: 'False'
    average: '0.05'
    axislabels: 'True'
