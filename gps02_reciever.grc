options:
  parameters:
    author: GPS01
    catch_exceptions: 'True'
    category: '[GRC Hier Blocks]'
    cmake_opt: ''
    comment: "GPS L1 C/A Receiver — RTL-SDR Educational Flow Graph\n\
      Frequency : 1575.42 MHz  (L1 = 154 \xD7 10.23 MHz)\n\
      Chip rate : 1.023 Mcps   (C/A Gold code)\n\
      Sample rate: 4.092 MSPS  (4 samples/chip)\n\
      Each block reflects one distinct mathematical operation."
    copyright: ''
    description: >-
      Receives GPS L1 C/A signal via RTL-SDR and decodes latitude/longitude.
      Every DSP and navigation step is an individual block so the signal
      processing mathematics is fully visible in the flow graph.
    gen_cmake: 'On'
    gen_linking: dynamic
    hier_block_src_path: '.:'
    id: gps01_receiver
    max_nouts: '0'
    output_language: python
    placement: [0, 0]
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: "GPS01 \u2014 RTL-SDR GPS L1 Receiver (Educational)"
    window_size: [3400, 2000]
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 8]
    rotation: 0
    state: enabled

# ═══════════════════════════════════════════════════════════════
#  VARIABLES
# ═══════════════════════════════════════════════════════════════

blocks:

- name: samp_rate
  id: variable
  parameters:
    comment: "4 \xD7 1.023e6 = 4.092 MSPS — 4 samples per GPS C/A chip"
    value: '4092000'
  states:
    coordinate: [200, 16]
    rotation: 0
    state: enabled

- name: gps_l1_freq
  id: variable
  parameters:
    comment: "L1 = 154 \xD7 f0, where f0 = 10.23 MHz fundamental"
    value: '1575420000'
  states:
    coordinate: [360, 16]
    rotation: 0
    state: enabled

- name: chip_rate
  id: variable
  parameters:
    comment: 'C/A chipping rate = f0 / 10 = 1.023 Mcps'
    value: '1023000'
  states:
    coordinate: [520, 16]
    rotation: 0
    state: enabled

- name: code_len_samples
  id: variable
  parameters:
    comment: '1023 chips × 4 samp/chip = 4092 samples per 1 ms epoch'
    value: '4092'
  states:
    coordinate: [680, 16]
    rotation: 0
    state: enabled

- name: sv_prn
  id: variable_qtgui_chooser
  parameters:
    comment: 'Active GPS satellite PRN to track (1-32)'
    label: 'Satellite PRN'
    num_opts: '8'
    option_labels: "['PRN 1','PRN 2','PRN 3','PRN 4','PRN 5','PRN 6','PRN 7','PRN 8']"
    options: '[1,2,3,4,5,6,7,8]'
    type: int
    value: '1'
    widget: combo_box
  states:
    coordinate: [840, 16]
    rotation: 0
    state: enabled

- name: if_freq_hz
  id: variable_qtgui_range
  parameters:
    comment: 'Manual IF frequency offset trim (Hz)'
    label: 'IF Offset (Hz)'
    min_len: '200'
    orient: QtCore.Qt.Horizontal
    rangeType: float
    start: '-20000'
    stop: '20000'
    step: '50'
    value: '0'
    widget: counter_slider
  states:
    coordinate: [1040, 16]
    rotation: 0
    state: enabled

- name: rtl_gain_db
  id: variable_qtgui_range
  parameters:
    comment: 'RTL-SDR front-end RF gain (dB)'
    label: 'RF Gain (dB)'
    min_len: '200'
    orient: QtCore.Qt.Horizontal
    rangeType: float
    start: '0'
    stop: '50'
    step: '0.5'
    value: '40'
    widget: counter_slider
  states:
    coordinate: [1240, 16]
    rotation: 0
    state: enabled

# ═══════════════════════════════════════════════════════════════
#  STEP 1 — RF FRONT END  (RTL-SDR Source)
# ═══════════════════════════════════════════════════════════════

- name: rtlsdr_source_0
  id: rtlsdr_source
  parameters:
    comment: "STEP 1 \u2014 RF FRONT END\n\
      Hardware: RTL2832U + R820T2 tuner\n\
      Center freq: 1575.42 MHz (GPS L1)\n\
      ADC: 8-bit I and Q → complex64 output\n\
      Noise figure \u2248 6 dB; GPS signal \u2248 \u221220 dB below thermal noise\n\
      kTB = 1.38e-23 \xD7 290 \xD7 4.09e6 \u2248 \u2212103 dBm  (noise floor)"
    affinity: ''
    alias: ''
    bandwidth: '2500000'
    bb_gain: '20'
    corr: '0'
    dc_offset_mode: '2'
    freq: gps_l1_freq
    freq_corr: '0'
    gain: rtl_gain_db
    gain_mode: 'False'
    if_gain: '20'
    iq_balance_mode: '2'
    maxoutbuf: '0'
    minoutbuf: '0'
    num_motherboards: '1'
    ppm: '0'
    sample_rate: samp_rate
    sync: sync
    time_source: ''
    type: fc32
  states:
    coordinate: [24, 288]
    rotation: 0
    state: enabled

