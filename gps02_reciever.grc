# ═══════════════════════════════════════════════════════════════
#  STEP 4 — PRN CODE GENERATOR  (Gold Codes)
# ═══════════════════════════════════════════════════════════════

- name: epy_prn_generator
  id: epy_block
  parameters:
    affinity: ''
    alias: ''
    comment: "STEP 4 \u2014 PRN CODE GENERATOR (Gold Codes)\n\
      Two 10-stage LFSRs combined via XOR:\n\
        G1(x) = x\xB9\xB0 + x\xB3 + 1           (feedback: taps 3, 10)\n\
        G2(x) = x\xB9\xB0+x\u2079+x\u2078+x\u2076+x\xB3+x\xB2+1  (feedback: 2,3,6,8,9,10)\n\
      C/A(n) = G1(n) \u2295 G2(n + phase_offset[sv])  mod 2\n\
      Maps {0,1} \u2192 {+1,\u22121}, upsampled to 4 samp/chip\n\
      Period = 1023 chips = 1 ms epoch"
    _io_cache: '(''PRN Code Generator'', ''blk'', [(''sv_prn'', ''1''), (''samp_rate'',
      ''4092000''), (''chip_rate'', ''1023000'')], [], [(''0'', ''complex'', 1)],
      ''GPS C/A Gold Code generator for a given satellite PRN.\n\nMath:\n  Two
      10-stage LFSRs with polynomial feedback.\n  G1 poly: x^10 + x^3 + 1\n  G2
      poly: x^10+x^9+x^8+x^6+x^3+x^2+1\n  CA(n) = G1(n) XOR G2(n + phase[sv])\n  Output:
      {+1,-1} upsampled to samp_rate/chip_rate samples per chip.'', {})'
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\n\nclass blk(gr.sync_block):\n\
      \    \"\"\"GPS C/A Gold Code Generator\n\n    Two 10-stage Linear Feedback\
      \ Shift Registers (LFSRs) whose XOR output\n    produces a unique 1023-chip\
      \ sequence for each GPS satellite PRN.\n\n    Math:\n        G1 polynomial:\
      \  x^10 + x^3 + 1          (feedback taps: 3, 10)\n        G2 polynomial:\
      \  x^10+x^9+x^8+x^6+x^3+x^2+1 (feedback taps: 2,3,6,8,9,10)\n        C/A(n)\
      \ = G1(n) XOR G2((n + phase_offset[sv]) mod 1023)\n\n    Output: complex64\
      \ stream of +1.0+0j / -1.0+0j chips, upsampled to\n            samp_rate /\
      \ chip_rate samples per chip (4 samp/chip @ 4.092 MSPS).\n    \"\"\"\n\n \
      \   # G2 phase assignments (chip delay per SV PRN 1..32)\n    _G2_PHASE =\
      \ [\n        5,  6,  7,  8, 17, 18, 139, 140, 141, 251,\n        252, 254,\
      \ 255, 256, 257, 258, 469, 470, 471, 472,\n        473, 474, 509, 512, 513,\
      \ 514, 515, 516, 859, 860,\n        861, 862\n    ]\n\n    def __init__(self,\
      \ sv_prn=1, samp_rate=4092000, chip_rate=1023000):\n        gr.sync_block.__init__(\n\
      \            self,\n            name='PRN Code Generator',\n            in_sig=None,\n\
      \            out_sig=[np.complex64]\n        )\n        self.sps = max(1, int(round(samp_rate\
      \ / chip_rate)))  # samples per chip\n        self._build_code(sv_prn)\n\n\
      \    def _build_code(self, sv):\n        \"\"\"Generate full 1023-chip C/A\
      \ code and upsample.\"\"\"\n        phase = self._G2_PHASE[(sv - 1) % 32]\n\
      \n        # Initialise both LFSRs to all-ones\n        g1 = [1] * 10\n    \
      \    g2 = [1] * 10\n\n        chips = np.empty(1023, dtype=np.float32)\n  \
      \      for i in range(1023):\n            g1_out = g1[9]                 \
      \     # tap 10 (index 9)\n            g2_out = g2[(phase - 1) % 10]      \
      \ # delayed tap\n            chips[i] = float(g1_out ^ g2_out)  # 0 or 1\n\
      \n            # Advance G1: feedback = tap3 XOR tap10\n            g1_fb =\
      \ g1[2] ^ g1[9]\n            g1 = [g1_fb] + g1[:-1]\n\n            # Advance\
      \ G2: feedback = tap2^tap3^tap6^tap8^tap9^tap10\n            g2_fb = g2[1]^\
      g2[2]^g2[5]^g2[7]^g2[8]^g2[9]\n            g2 = [g2_fb] + g2[:-1]\n\n   \
      \     # {0,1} -> {+1,-1}  then upsample to samp_rate\n        bipolar = (1.0\
      \ - 2.0 * chips).astype(np.float32)\n        upsampled = np.repeat(bipolar,\
      \ self.sps)\n        self._code = (upsampled + 0j).astype(np.complex64)\n \
      \       self._len = len(self._code)   # = 4092 at 4.092 MSPS\n        self._idx\
      \ = 0\n\n    def work(self, input_items, output_items):\n        n = len(output_items[0])\n\
      \        out = output_items[0]\n        # Wrap-around indexing into the 1 ms\
      \ code epoch\n        for i in range(n):\n            out[i] = self._code[self._idx\
      \ % self._len]\n            self._idx += 1\n        return n\n"
    maxoutbuf: '0'
    minoutbuf: '0'
    sv_prn: sv_prn
    samp_rate: samp_rate
    chip_rate: chip_rate
  states:
    coordinate: [576, 600]
    rotation: 0
    state: enabled

