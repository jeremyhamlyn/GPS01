    fftsize: '4096'
    freqhalf: 'True'
    grid: 'True'
    gui_hint: 'tabs@0:1,0,1,2'
    label: Filtered Spectrum
    label1: Filtered GPS L1
    legend: 'True'
    maxoutbuf: '0'
    minoutbuf: '0'
    name: '"STEP 2: Bandlimited (FIR, BW=2.046 MHz)"'
    nconnections: '1'
    norm_window: 'False'
    showports: 'False'
    tr_chan: '0'
    tr_level: '0.0'
    tr_mode: qtgui.TRIG_MODE_FREE
    tr_tag: '""'
    type: complex
    units: dB
    update_time: '0.10'
    width1: '1'
